        "# ==============================================================================\n",
        "# FRAMEWORK MÖBIUS-TESSERACT: VARREDURA DE FASE ESPELHO (MINIMIZAÇÃO CHI-QUADRADO)\n",
        "# Foco: Ajuste Fino do parâmetro Delta_Phi_c aos dados macroscópicos H(z)\n",
        "# ==============================================================================\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "print(\"[1/4] Carregando motor de busca estocástica (Qui-Quadrado)...\")\n",
        "\n",
        "# Parâmetros fixados dos testes anteriores\n",
        "alpha_w = 1.7970\n",
        "omega_m = 0.3\n",
        "omega_lambda = 0.7\n",
        "\n",
        "# Dados simulados representando a expansão medida pelo DESI (H(z) vs Redshift)\n",
        "z_obs = np.array([0.3, 0.5, 0.7, 0.9, 1.1, 1.3, 1.5, 1.8, 2.1])\n",
        "h_obs = np.array([1.10, 1.25, 1.45, 1.65, 1.85, 2.10, 2.35, 2.75, 3.25])\n",
        "erros = np.array([0.04, 0.05, 0.06, 0.07, 0.08, 0.09, 0.10, 0.12, 0.15])\n",
        "\n",
        "print(\"[2/4] Executando varredura do Deslocamento de Fase (Delta_Phi_c)...\")\n",
        "# Varrendo ângulos de fase de 0 a Pi (0 a 3.14 radianos)\n",
        "fases_teste = np.linspace(0, np.pi, 500)\n",
        "melhor_fase = 0\n",
        "menor_chi2 = float('inf')\n",
        "melhor_curva_h = []\n",
        "\n",
        "# Loop de Minimização de Erro (Equação de Calibração do Framework)\n",
        "for fase in fases_teste:\n",
        "    # Calculando a curva teórica do Möbius para esta fase específica\n",
        "    modulacao_espelho = np.cos(z_obs + fase)\n",
        "    # Aceleração cósmica compensada pela tensão da brana (Energia Escura Geométrica)\n",
        "    h_teorico = np.sqrt(omega_m * (1 + z_obs)**3 + (omega_lambda * (alpha_w * 0.55) * np.abs(modulacao_espelho)))\n",
        "\n",
        "    # Cálculo do Erro Estatístico Qui-Quadrado (Chi^2)\n",
