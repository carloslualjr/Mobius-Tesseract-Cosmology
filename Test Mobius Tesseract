        "plt.axvline(x=melhor_alpha_w, color='r', linestyle='--', label=f'Acoplamento Ótimo ({melhor_alpha_w:.2f})')\n",
        "plt.title(\"Varredura Estocástica do Acoplamento de Weyl\")\n",
        "plt.xlabel(\"Coeficiente Adimensional (alpha_w)\")\n",
        "plt.ylabel(\"Índice de Alinhamento Quiral\")\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "\n",
        "# Plot 2: Comportamento do Fator Conforme na Garganta Métrica\n",
        "plt.subplot(1, 2, 2)\n",
        "plt.plot(raios, omega_dinamico, 'b-', label='Potencial Omega(r) Regularizado')\n",
        "plt.axvline(x=1.0, color='purple', linestyle=':', label='Fronteira Planckiana (l_P)')\n",
