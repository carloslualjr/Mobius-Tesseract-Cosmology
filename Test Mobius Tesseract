        "plt.xlabel(\"Raio de Coordenada (r/l_P)\")\n",
        "plt.ylabel(\"Fator Conforme \\u03a9(r)\")\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
